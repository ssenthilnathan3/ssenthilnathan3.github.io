<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Senthilnathan" href="/feed.xml" />
  <link rel="canonical" href="<%= config[:site_url] %><%= current_page.url %>" />
  <title><%= current_page.data.title %> — Senthilnathan</title>
  <meta name="title" content="<%= current_page.data.title %> — Senthilnathan" />
  <meta name="description" content="<%= current_page.data.description || config[:site_description] %>" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="<%= config[:site_url] %><%= current_page.url %>" />
  <meta property="og:title" content="<%= current_page.data.title %>" />
  <meta property="og:description" content="<%= current_page.data.description || config[:site_description] %>" />
  <% if current_page.data.hero_image %>
  <meta property="og:image" content="<%= config[:site_url] %><%= current_page.data.hero_image %>" />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:image" content="<%= config[:site_url] %><%= current_page.data.hero_image %>" />
  <% else %>
  <meta property="twitter:card" content="summary" />
  <% end %>
  <meta property="twitter:title" content="<%= current_page.data.title %>" />
  <meta property="twitter:description" content="<%= current_page.data.description || config[:site_description] %>" />
  <link rel="stylesheet" href="/stylesheets/global.css" />
  <link rel="stylesheet" href="/stylesheets/blog-post.css" />
  <!-- Interactive widget styles (only loaded when needed) -->
  <link rel="stylesheet" href="/stylesheets/widgets.css" />
</head>
<body>
  <main class="content-wrapper">
    <nav class="back-nav">
      <a href="/" class="back-link">← Home</a>
    </nav>

    <article class="prose">
      <header class="article-header">
        <div class="article-meta">
          <time datetime="<%= current_page.date.strftime('%Y-%m-%d') %>">
            <%= current_page.date.strftime('%b %-d, %Y') %>
          </time>
          <% if current_page.data.updated_date %>
            <span class="last-updated-on">
              · Updated <%= Date.parse(current_page.data.updated_date.to_s).strftime('%b %-d, %Y') %>
            </span>
          <% end %>
        </div>
        <h1 class="title"><%= current_page.data.title %></h1>
        <% if current_page.data.description %>
          <p class="description"><%= current_page.data.description %></p>
        <% end %>
        <hr />
      </header>

      <% if current_page.data.hero_image %>
        <figure class="hero-image">
          <div class="hero-frame">
            <img
              src="<%= current_page.data.hero_image %>"
              alt="<%= current_page.data.title %>"
              loading="eager"
              decoding="async"
            />
          </div>
          <% if current_page.data.hero_image_source %>
            <figcaption class="hero-source">source: <%= current_page.data.hero_image_source %></figcaption>
          <% end %>
        </figure>
      <% end %>

      <div class="article-content">
        <%= yield %>
      </div>
    </article>

    <footer class="article-footer">
      <a href="/blog/" class="back-link">← All posts</a>
    </footer>
  </main>

  <!-- Widget JS (only loaded on blog posts that use them) -->
  <script src="/javascripts/widgets.js"></script>
</body>
</html>
