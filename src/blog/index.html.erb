---
title: Blog
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Senthilnathan" href="/feed.xml" />
  <link rel="canonical" href="<%= config[:site_url] %>/blog/" />
  <title>Blog — Senthilnathan</title>
  <meta name="title" content="Blog — Senthilnathan" />
  <meta name="description" content="<%= config[:site_description] %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= config[:site_url] %>/blog/" />
  <meta property="og:title" content="Blog — Senthilnathan" />
  <meta property="og:description" content="<%= config[:site_description] %>" />
  <link rel="stylesheet" href="/stylesheets/global.css" />
  <link rel="stylesheet" href="/stylesheets/blog-index.css" />
</head>
<body>
  <main>
    <div class="container">
      <div class="header">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
          Home
        </a>
        <h1 class="title">Shelf</h1>
      </div>

      <%
        all_posts = blog.articles.reject { |a| a.data[:draft] }.sort_by { |a| a.date }.reverse
      %>

      <% if all_posts.empty? %>
        <div class="empty-state">No posts yet.</div>
      <% else %>
        <div class="posts-list">
          <% all_posts.each do |post| %>
            <a href="<%= post.url %>" class="post-item">
              <div class="post-header">
                <span class="post-date">
                  <%= post.date.strftime('%b %-d, %Y') %>
                  <span class="post-category"><%= post.data[:category] || 'misc' %></span>
                </span>
                <svg class="post-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
              <span class="post-title"><%= post.title %></span>
              <span class="post-desc"><%= post.data[:description] %></span>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>
  </main>
</body>
</html>
