<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" id="favicon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Senthilnathan" href="/feed.xml" />
  <link rel="canonical" href="<%= config[:site_url] %>" />
  <title>Senthilnathan</title>
  <meta name="title" content="Senthilnathan" />
  <meta name="description" content="<%= config[:site_description] %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= config[:site_url] %>" />
  <meta property="og:title" content="Senthilnathan" />
  <meta property="og:description" content="<%= config[:site_description] %>" />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content="Senthilnathan" />
  <meta property="twitter:description" content="<%= config[:site_description] %>" />
  <link rel="stylesheet" href="/stylesheets/global.css" />
</head>

<body>
  <!-- Eye Floaters -->
  <div class="floaters-container" aria-hidden="true">
    <svg class="floater f1" viewBox="0 0 100 100" width="100" height="100">
      <path d="M10,50 Q30,20 50,50 T90,50" fill="none" stroke="currentColor" stroke-width="2" opacity="0.4"></path>
    </svg>
    <svg class="floater f2" viewBox="0 0 50 50" width="60" height="60">
      <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"></circle>
      <circle cx="25" cy="25" r="8" fill="currentColor" opacity="0.1"></circle>
    </svg>
    <svg class="floater f3" viewBox="0 0 120 40" width="120" height="40">
      <path d="M10,20 C30,10 30,30 50,20 S70,30 90,20" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"></path>
    </svg>
    <svg class="floater f4" viewBox="0 0 80 80" width="80" height="80">
      <path d="M40,10 Q60,40 40,70" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"></path>
    </svg>
  </div>

  <!-- Chaos Rings -->
  <div id="chaos-container">
    <svg id="chaos-svg" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>
  <a id="chaos-center-btn" href="/blog/" aria-label="Open Blogshelf">
    <img src="/images/cat-vibe.gif" alt="Vibing Cat" class="center-gif" />
  </a>

  <!-- Chaos Widgets -->
  <article class="chaos-widget widget-pong">
    <div class="widget-header"><h3>Play a game?</h3></div>
    <canvas id="pong-canvas" width="272" height="120" style="background: #111; margin-top: var(--space-3); border-radius: var(--radius-md); display: block;"></canvas>
  </article>

  <article class="chaos-widget widget-p5">
    <div class="widget-header"><h3>Generative Flow</h3></div>
    <div id="p5-container" style="margin-top: var(--space-3); border-radius: var(--radius-md); overflow: hidden; height: 120px;"></div>
  </article>

  <div class="chaos-widget widget-tv">
    <img src="/images/charlie-spinning-tv.gif" alt="Spinning TV" />
  </div>
  <div class="chaos-widget widget-listening">
    <img src="/images/listening.gif" alt="Listening" />
  </div>
  <div class="chaos-widget widget-music">
    <div class="widget-header"><h3>Listen to a Song?</h3></div>
    
    <div class="music-player-container">
      <div class="track-details">
        <div class="artwork-wrapper">
          <img id="music-artwork" src="" alt="Album Art" />
        </div>
        <div class="track-text">
          <div id="music-title">No Track Loaded</div>
          <div id="music-artist">Unknown Artist</div>
        </div>
      </div>
      
      <div class="player-controls">
        <button id="music-play-btn" class="control-btn" aria-label="Play/Pause">
          <svg id="play-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg id="pause-icon" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        <button id="music-shuffle-btn" class="control-btn" aria-label="Shuffle">
          <svg id="shuffle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg>
        </button>
        
        <div class="progress-container">
          <div id="progress-bar" class="progress-bar"></div>
        </div>
      </div>
    </div>

    <audio id="regional-player" style="display: none;"></audio>
  </div>

  <main>
    <section class="intro">
      <h1 class="greeting">
        hello, i'm <span class="name"><%= config[:author_name] %></span><button
          id="chaos-toggle"
          class="chaos-toggle"
          aria-label="Toggle Chaos Mode"
        >
          <span class="toggle-track">
            <span class="toggle-thumb"></span>
          </span>
        </button>
      </h1>

      <p class="lead"><%= config[:site_description] %></p>

      <p>
        this site is a collection of my writing, notes, and
        experiments. i'm interested in the intersection of design
        and engineering.
      </p>

      <nav class="nav-links">
        <a href="/blog/">shelf</a>
        <a href="/about/">about</a>
        <a href="/feed.xml">rss</a>
      </nav>
    </section>
  </main>

  <footer class="footer">
    <p>&copy; <%= Time.now.year %> <%= config[:author_name] %></p>
  </footer>

  <link rel="stylesheet" href="/stylesheets/index.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
  <script src="/javascripts/chaos-rings.js"></script>
  <script src="/javascripts/chaos-pong.js"></script>
  <script src="/javascripts/chaos-p5.js"></script>
  <script src="/javascripts/chaos-music.js"></script>
  <script src="/javascripts/chaos-toggle.js"></script>
</body>
</html>
